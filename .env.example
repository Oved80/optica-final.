# Ejemplo de variables de entorno para desarrollo (Vite)
# Copia este archivo a .env y completa con tus valores reales.
# NO añadir .env al control de versiones.

VITE_SUPABASE_URL=https://xyzcompany.supabase.co
VITE_SUPABASE_ANON_KEY=pk.XXXX_your_public_key_here_XXXX
# Nombre del bucket donde se guardarán los archivos de examenes
VITE_SUPABASE_BUCKET_NAME=examenes

# Opcional: nombre del bucket público si usas otro para archivos públicos
# VITE_SUPABASE_PUBLIC_BUCKET=public
